      <msgDisplay l="ru">за поясом</msgDisplay>
      <msgDisplay l="ua">за поясом</msgDisplay>
      <msgRoomWear>%1$^C1 затыка%1$nет|ют %2$O4 за пояс.</msgRoomWear>
      <msgSelfWear l="en">You tuck %2$O4 into your belt.</msgSelfWear>
